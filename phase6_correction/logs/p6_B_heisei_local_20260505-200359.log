+    exists = cur.execute(
+        "SELECT 1 FROM achievers WHERE name_ja=? AND birth_year IS ?",
+        (person["name_ja"], person["birth_year"]),
+    ).fetchone()
+    if exists:
+        return 0
+
+    cur.execute(
