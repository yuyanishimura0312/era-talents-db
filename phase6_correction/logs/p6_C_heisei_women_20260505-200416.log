+#!/usr/bin/env python3
+import sqlite3
+from pathlib import Path
+from urllib.parse import quote
+
+
+DB_PATH = Path(__file__).resolve().parents[1] / "data" / "era_talents.db"
+TEAM = "codex_correction_heisei_women"
+PHASE = "6.C"
+TARGET = 300
+
