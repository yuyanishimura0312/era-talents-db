投入は `achievers` に人物を入れ、その直後に同じ `lastrowid` へ3件ずつ能力根拠を入れる形にします。バッチは50件ごとに `commit` し、重複判定は指定どおり `name_ja` と `birth_year IS ?` で実行します。
exec
/bin/bash -lc "python3 - <<'PY'
import sqlite3, json
DB='data/era_talents.db'
SOURCE_TEAM='codex_correction_showa_post_craft'
PHASE='6.B'
LNT_URL='https://jmedia.wiki/%E4%BA%BA%E9%96%93%E5%9B%BD%E5%AE%9D%E4%B8%80%E8%A6%A7%EF%BC%88%E5%B7%A5%E8%8A%B8%E5%93%81%EF%BC%89/List_of_Living_National_Treasures_of_Japan_%28crafts%29'
BUNKACHO_URL='https://www.bunka.go.jp/seisaku/bunkazai/shokai/mukei/'
MOA_URL='https://www.moaart.or.jp/events/waza_living_national_treasure/'

def r(name,birth,death,sub,summary,works=None,url=None,great=1,woman=False):
    if woman and '女性' not in summary:
        summary = '女性。' + summary
    return dict(name_ja=name,birth_year=birth,death_year=death,sub_domain=sub,summary=summary,works=works or [sub],url=url or LNT_URL,great=great,woman=woman)

