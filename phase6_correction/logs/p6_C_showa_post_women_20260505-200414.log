+        if len(selected) == TARGET:
+            break
+    if len(selected) < TARGET:
+        raise SystemExit(f"only {len(selected)} insertable candidates; skipped={len(skipped)}")
+
+    for start in range(0, len(selected), 50):
+        batch = selected[start : start + 50]
