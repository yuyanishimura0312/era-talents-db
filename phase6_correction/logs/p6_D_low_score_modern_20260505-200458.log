def parse():
    out=[]
    for line in RAW.strip().splitlines():
        parts=line.split('|')
        if len(parts)"'!=9:
            raise ValueError((len(parts), line))
        ja,en,birth,death,era,domain,sub,issue,url=parts
        out.append(dict(name_ja=ja,name_en=en,birth_year=int(birth),death_year=int(death) if death else None,era=era,domain=domain,sub=sub,issue=issue,url=url))
    return out

