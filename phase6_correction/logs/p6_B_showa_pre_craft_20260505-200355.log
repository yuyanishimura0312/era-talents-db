)
SELECT name_ja, NULL, 'showa_pre', 'showa_post', 'craft', sub_domain,
       name_ja || 'は、' || sub_domain || 'の地域工芸・伝統工芸士系統に属する職人・工芸家。昭和前期以前から続く産地技法の継承者として、政治・中央文化偏重を補正するため追加。',
       '[]', 'other', '地域工房・産地内修業', 'traditional_craft_registry',
