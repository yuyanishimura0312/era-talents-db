+        )
+        """,
+        (TEAM, PHASE),
+    )
+    capabilities_count = cur.fetchone()[0]
+    print(f"done achievers={achievers_count} capabilities={capabilities_count} skipped_existing_names={len(skipped)}")
+    con.close()
