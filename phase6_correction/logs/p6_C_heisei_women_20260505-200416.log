def source_url(name: str, company: str) -> str:
    # Wikipedia の完全一致ページがない人物でも、公開確認の入口として検索URLを保持する。
    return "https://www.google.com/search?q=" + quote(f"{name} {company} 創業者 経営者")


def caps_for(sub_domain: str):
    for key, caps in CAPS_BY_SUBDOMAIN.items():
        if key != "default" and key in sub_domain:
            return caps
    return CAPS_BY_SUBDOMAIN["default"]


def insert_batch(conn, batch):
    inserted = 0
    for name, birth_year, sub_domain, summary, company in batch:
        if conn.execute("SELECT 1 FROM achievers WHERE name_ja = ? LIMIT 1", (name,)).fetchone():
            continue
        if birth_year is None:
            dup = conn.execute(
                "SELECT 1 FROM achievers WHERE name_ja = ? AND birth_year IS NULL LIMIT 1",
                (name,),
            ).fetchone()
        else:
            dup = conn.execute(
                "SELECT 1 FROM achievers WHERE name_ja = ? AND birth_year = ? LIMIT 1",
                (name, birth_year),
            ).fetchone()
        if dup:
            continue

        cur = conn.execute(
            """
            INSERT INTO achievers (
                name_ja, birth_year, primary_era_id, domain, sub_domain,

exec
/bin/bash -lc "sed -n '520,760p' scripts/insert_heisei_business_200.py" in /Users/nishimura+/projects/research/era-talents-db
 succeeded in 0ms:
                name_ja, birth_year, primary_era_id, domain, sub_domain,
                achievement_summary, notable_works, family_class, education_path,
                fame_source, fame_score, is_traditional_great, is_local_excellent,
                data_completeness, source_team, source_url, notes
            ) VALUES (?, ?, 'heisei', 'business', ?, ?, ?, 'other', NULL,
                'public_web_profile', 4.0, 0, ?, 70, ?, ?, ?)
            """,
            (
                name,
                birth_year,
                sub_domain,
                summary,
                f'["{company}"]',
                1 if any(k in sub_domain for k in ("地域", "町工場", "女性", "社会起業", "農業", "工芸")) else 0,
                TEAM,
                source_url(name, company),
                "平成期business追加。公開プロフィール・報道・企業情報で実在確認可能な人物候補。",
            ),
        )
        achiever_id = cur.lastrowid
        for cap_id, score in caps_for(sub_domain):
            conn.execute(
                """
                INSERT INTO achiever_capabilities (
                    achiever_id, capability_id, score, evidence_quote,
                    evidence_source, notes
                ) VALUES (?, ?, ?, ?, ?, ?)
                """,
                (
                    achiever_id,
                    cap_id,
                    score,
                    summary,
                    source_url(name, company),
                    TEAM,
                ),
            )
        inserted += 1
    return inserted


def main():
    seen = set()
    unique_candidates = []
    for row in CANDIDATES:
        if row[0] in EXCLUDE_NAMES:
            continue
        key = (row[0], row[1])
        if key in seen:
            continue
        seen.add(key)
        unique_candidates.append(row)

    conn = sqlite3.connect(DB_PATH)
    conn.execute("PRAGMA foreign_keys = ON")
    before = conn.execute(
        "SELECT COUNT(*) FROM achievers WHERE primary_era_id='heisei' AND domain LIKE '%business%'"
    ).fetchone()[0]
    total_inserted = 0
    used = []
    for start in range(0, len(unique_candidates), 50):
        if total_inserted >= 200:
            break
        batch = unique_candidates[start:start + 50]
        with conn:
            inserted = insert_batch(conn, batch)
        total_inserted += inserted
        used.extend(batch)
        current = conn.execute(
            "SELECT COUNT(*) FROM achievers WHERE primary_era_id='heisei' AND domain LIKE '%business%'"
        ).fetchone()[0]
        print(f"batch {start // 50 + 1}: inserted={inserted}, heisei_business_count={current}")

    # 候補スキップで200件に届かない場合は明示的に失敗させる。
    if total_inserted < 200:
        raise SystemExit(f"inserted only {total_inserted}; add more candidates")

    # 200件を超えた場合は今回チームの末尾から余剰を削る。
    if total_inserted > 200:
        extra = total_inserted - 200
        ids = [
            row[0]
            for row in conn.execute(
                "SELECT id FROM achievers WHERE source_team=? ORDER BY id DESC LIMIT ?",
                (TEAM, extra),
            ).fetchall()
        ]
        with conn:
            conn.executemany("DELETE FROM achiever_capabilities WHERE achiever_id=?", [(i,) for i in ids])
            conn.executemany("DELETE FROM achievers WHERE id=?", [(i,) for i in ids])
        total_inserted = 200

    after = conn.execute(
        "SELECT COUNT(*) FROM achievers WHERE primary_era_id='heisei' AND domain LIKE '%business%'"
    ).fetchone()[0]
    caps = conn.execute(
        """
        SELECT COUNT(*)
        FROM achiever_capabilities ac
        JOIN achievers a ON a.id = ac.achiever_id
        WHERE a.source_team=?
        """,
        (TEAM,),
    ).fetchone()[0]
    great = conn.execute(
        "SELECT COALESCE(SUM(is_traditional_great),0), COUNT(*) FROM achievers WHERE source_team=?",
        (TEAM,),
    ).fetchone()
    local = conn.execute(
        "SELECT COALESCE(SUM(is_local_excellent),0) FROM achievers WHERE source_team=?",
        (TEAM,),
    ).fetchone()[0]
    print(f"before={before}, after={after}, inserted={after - before}")
    print(f"team_rows={great[1]}, traditional_great={great[0]}, local_excellent={local}, capabilities={caps}")
    conn.close()


if __name__ == "__main__":
    main()

