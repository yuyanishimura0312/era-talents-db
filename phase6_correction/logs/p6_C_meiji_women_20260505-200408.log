+                family_education, education_path, mentors, fame_source, fame_score,
+                is_traditional_great, is_local_excellent, data_completeness, source_team,
+                source_url, notes, correction_phase
+            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
+            """,
+            (
+                p["name_ja"],
+                p["name_en"],
+                p["birth_year"],
+                p["death_year"],
+                p["primary_era_id"],
+                p["secondary_era_id"],
+                p["domain"],
+                p["sub_domain"],
+                p["achievement_summary"],
+                "[]",
+                None,
+                None,
+                "女性教育・専門職参入が制度的に制約された時代に、学習・実践・組織化を通じて専門領域を開いた。",
+                "[]",
+                "wikipedia_or_authority_reference",
+                4.5,
+                0,
+                0,
+                70,
+                TEAM,
+                p["source_url"],
+                "Phase 6.C meiji_women correction: verified public-reference entry; summary explicitly marks woman pioneer.",
+                PHASE,
+            ),
+        )
+        achiever_id = cur.lastrowid
+        for cap_id, score in caps_for(p["sub_domain"]):
+            cur.execute(
+                """
+                INSERT INTO achiever_capabilities (
+                    achiever_id, capability_id, score, evidence_quote, evidence_source, notes, is_uniform_bulk
+                ) VALUES (?, ?, ?, ?, ?, ?, ?)
+                """,
+                (
+                    achiever_id,
+                    cap_id,
+                    score,
+                    p["achievement_summary"],
+                    p["source_url"],
+                    "Phase 6.C women pioneer capability scoring; scores intentionally vary by role.",
+                    0,
+                ),
+            )
+        inserted += 1
+        if inserted % 50 == 0:
+            conn.commit()
+            print(f"committed batch: {inserted}")
+        if inserted >= TARGET:
+            break
+    conn.commit()
+    print(f"inserted={inserted}")
+    print(f"skipped_duplicates={len(skipped)}")
+    if inserted < TARGET:
+        print("WARNING target not reached")
+    conn.close()
+
+
+if __name__ == "__main__":
+    main()

