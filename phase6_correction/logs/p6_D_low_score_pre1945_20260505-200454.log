def source_url(name):
    return 'https://ja.wikipedia.org/wiki/' + name.replace(' ', '_')

def era_for_birth_active(era): return era

def base_caps(domain, low_cap, low_score, low_note, source):
    caps = [(low_cap, low_score, low_note, source, '低スコア根拠')]
    if domain in ('politics','military','social_movement'):
        caps += [('cog_systems',7,'組織・制度・戦略を動かす能力は同時代の活動実績から確認できる。',source,'主要能力'),('soc_interpersonal',6,'支持者・組織・官僚制を動員した実績がある。',source,'主要能力')]
        if low_cap "'!= '"'cog_critical': caps.append(('cog_critical',5,'批判的研究では判断の偏りや視野狭窄も指摘される。',source,'補助能力'))
    elif domain in ('business','technology','professional'):
        caps += [('age_entrepreneur',8,'事業・技術・制度を立ち上げ拡大した実績がある。',source,'主要能力'),('cog_systems',7,'複雑な組織や技術体系を構成した。',source,'主要能力')]
        if low_cap "'!= '"'soc_interpersonal': caps.append(('soc_interpersonal',5,'労使・顧客・協働面では摩擦や批判も残した。',source,'補助能力'))
    elif domain in ('culture_arts','media','education','science','religion'):
        caps += [('cog_creativity',8,'作品・理論・表現形式で独自性を示した。',source,'主要能力'),('cog_info',7,'言説・情報・表象を社会へ広める力があった。',source,'主要能力')]
        if low_cap "'!= '"'soc_interpersonal': caps.append(('soc_interpersonal',5,'協働・対人関係には批判的評価もある。',source,'補助能力'))
    else:
        caps += [('cog_systems',6,'活動領域で一定の制度的成果を残した。',source,'主要能力'),('soc_interpersonal',6,'支持者や関係者を動かした。',source,'主要能力')]
    # unique by capability, keep low first
    seen=set(); out=[]
    for cap in caps:
        if cap[0] not in seen:
            seen.add(cap[0]); out.append(cap)
    return out[:5]

conn=sqlite3.connect(DB)
cur=conn.cursor()
inserted=0; skipped=[]; inserted_names=[]
cur.execute('BEGIN')
for r in rows:
    if inserted >= 150:
        break
    name,en,birth,death,era,domain,sub,summary,low_cap,low_score,low_note,src = r
    # required duplicate check before insert
    cur.execute('SELECT 1 FROM achievers WHERE name_ja=? AND birth_year IS ?', (name,birth))
    if cur.fetchone():
        skipped.append(name); continue
    cur.execute('''INSERT INTO achievers
      (name_ja,name_en,name_kana,birth_year,death_year,birth_place,primary_era_id,secondary_era_id,domain,sub_domain,achievement_summary,notable_works,family_class,family_education,education_path,mentors,fame_source,fame_score,is_traditional_great,is_local_excellent,data_completeness,source_team,source_url,notes,correction_phase)
      VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)''',
      (name,en,None,birth,death,None,era,None,domain,sub,summary,json.dumps([],ensure_ascii=False),'other',None,None,json.dumps([],ensure_ascii=False),'wikipedia_ja',65.0,1,0,72,SOURCE_TEAM,source_url(name),'Phase 6.D low_score_pre1945: 批判的伝記研究・同時代評価のネガティブ面に基づき、低スコア能力を明示。',PHASE))
    aid=cur.lastrowid
    for cap_id,score,quote,esrc,note in base_caps(domain,low_cap,low_score,low_note,src):
        cur.execute('''INSERT INTO achiever_capabilities (achiever_id, capability_id, score, evidence_quote, evidence_source, notes, is_uniform_bulk) VALUES (?,?,?,?,?,?,0)''',
                    (aid,cap_id,int(score),quote,esrc,note))
    inserted += 1; inserted_names.append(name)
    if inserted % 50 == 0:
        conn.commit(); cur.execute('BEGIN')
conn.commit()
print('inserted', inserted)
print('skipped', len(skipped), skipped[:30])
print('last', inserted_names[-5:])
if inserted < 150:
    raise SystemExit(f'only inserted {inserted}; need more candidates')
