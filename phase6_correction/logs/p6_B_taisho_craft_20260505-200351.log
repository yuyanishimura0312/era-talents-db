+            break
+        result = insert_person(cur, name, birth, death)
+        if result is None:
+            skipped += 1
+            continue
+        achiever_id, summary = result
+        insert_capabilities(cur, achiever_id, summary)
+        inserted += 1
+        batch_count += 1
+
+        if batch_count == 50:
