def caps_for(domain, issue):
    if domain in ('business','technology'):
        return [('age_entrepreneur',8,'事業構築・市場形成で平成・令和期に大きな影響を与えた。'),('cog_systems',7,'組織・技術・市場を結びつける構想力が確認できる。'),('val_collective',4,issue)]
    if domain=='politics':
