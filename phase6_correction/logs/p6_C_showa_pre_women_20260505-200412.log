def wiki_url(name_en: str) -> str:
    return "https://en.wikipedia.org/wiki/" + quote(name_en.replace(" ", "_"))


def parse():
    rows = []
    seen = set()
    for line in RAW.splitlines():
        parts = line.split("|")
        if len(parts) != 7:
            raise ValueError(f"bad row: {line}")
        name_ja, name_en, birth, death, kind, sub, summary = parts
