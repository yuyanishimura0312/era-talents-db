+                        '[]', 'other', NULL, NULL, '[]',
+                        'wikipedia_ja_or_public_biographical_reference', ?,
+                        0, 0, 74, ?, ?, ?, ?)
+                    """,
+                    (
+                        r["name_ja"],
+                        r["name_en"],
+                        r["birth_year"],
+                        r["death_year"],
+                        r["sub_domain"],
+                        r["summary"],
