+                data_completeness, source_team, source_url, notes, correction_phase
+            ) VALUES (?, ?, 'reiwa', ?, 'regional_revitalization_dendoushi',
+                ?, ?, 'other', NULL, 'cabinet_office_regional_revitalization_dendoushi',
+                4.5, 0, 1, 70, ?, ?, ?, ?)
