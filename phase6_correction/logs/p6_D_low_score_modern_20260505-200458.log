    if domain=='sports':
        return [('age_resilience',8,'競技成績や復帰過程から高い身体的・心理的レジリエンスが確認できる。'),('cog_systems',6,'競技戦略や専門技能の体系的習得が確認できる。'),('val_collective',4,issue)]
    if domain in ('culture_arts','media'):
        return [('cog_creativity',8,'作品・番組・発信で同時代文化に大きな影響を与えた。'),('soc_interpersonal',6,'大衆・業界ネットワークを通じて活動を拡大した。'),('val_tolerance',4,issue)]
    if domain in ('science','education'):
        return [('cog_logical',8,'研究・政策分析・専門知識の蓄積で影響を残した。'),('cog_info',7,'専門情報の生成・発信で同時代に影響を与えた。'),('cog_critical',4,issue)]
    return [('cog_systems',7,'平成・令和期の活動で専門領域に影響を与えた。'),('age_resilience',6,'活動継続に一定の適応性が確認できる。'),('val_collective',4,issue)]

