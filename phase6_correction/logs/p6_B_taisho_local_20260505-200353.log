+def existing_id(conn: sqlite3.Connection, name: str, birth_year: int | None):
+    if birth_year in (None, 0):
+        row = conn.execute(
+            "SELECT id FROM achievers WHERE name_ja=? AND birth_year IS NULL",
+            (name,),
+        ).fetchone()
+    else:
+        row = conn.execute(
+            "SELECT id FROM achievers WHERE name_ja=? AND birth_year IS ?",
+            (name, birth_year),
+        ).fetchone()
+    if row:
+        return row[0]
+    # Stronger guard than the required check: do not create same-name variants.
+    row = conn.execute("SELECT id FROM achievers WHERE name_ja=?", (name,)).fetchone()
+    return row[0] if row else None
+
+
+def insert_batch(conn: sqlite3.Connection, batch):
+    for name, birth_year, death_year, domain, sub_domain, summary_tail in batch:
+        by = None if birth_year == 0 else birth_year
+        dy = None if death_year == 0 else death_year
+        if existing_id(conn, name, by):
+            continue
+        summary = f"{name}は大正期前後の{sub_domain}で活動し、{summary_tail}。"
+        source_url = w(name)
+        cur = conn.execute(
+            """
+            INSERT INTO achievers (
+                name_ja, birth_year, death_year, birth_place,
+                primary_era_id, domain, sub_domain, achievement_summary,
+                notable_works, family_class, education_path,
+                fame_source, fame_score, is_traditional_great, is_local_excellent,
+                data_completeness, source_team, source_url, notes, correction_phase
+            ) VALUES (?, ?, ?, NULL, 'taisho', ?, ?, ?, ?, 'other', NULL,
+                      'wikipedia_ja', 35, 0, 1, ?, ?, ?, ?, ?)
+            """,
+            (
+                name,
+                by,
+                dy,
+                domain,
+                sub_domain,
+                summary,
+                json.dumps([sub_domain], ensure_ascii=False),
+                72 if by else 58,
+                TEAM,
+                source_url,
+                "Phase 6.B taisho_local: politics偏重補正のため、地域産業・農村実践・地方文化に関わる実在人物を追加。",
+                PHASE,
+            ),
+        )
+        achiever_id = cur.lastrowid
+        for cap_id, score in DOMAIN_CAPS[domain]:
+            conn.execute(
+                """
+                INSERT INTO achiever_capabilities (
+                    achiever_id, capability_id, score, evidence_quote, evidence_source, notes
+                ) VALUES (?, ?, ?, ?, ?, ?)
+                """,
+                (
+                    achiever_id,
+                    cap_id,
+                    score,
+                    summary,
+                    source_url,
+                    "Phase 6.B taisho_local scoring: domain-specific local practice evidence.",
+                ),
+            )
+
+
+def main():
+    conn = sqlite3.connect(DB_PATH)
+    conn.execute("PRAGMA foreign_keys=ON")
+
+    start = conn.execute(
+        "SELECT COUNT(*) FROM achievers WHERE correction_phase=? AND source_team=?",
+        (PHASE, TEAM),
+    ).fetchone()[0]
+
+    selected = []
+    seen = set()
+    for row in CANDIDATES:
+        name, birth_year, *_ = row
+        by = None if birth_year == 0 else birth_year
+        key = (name, by)
+        if key in seen:
+            continue
+        seen.add(key)
+        if not existing_id(conn, name, by):
+            selected.append(row)
+        if len(selected) == 150:
+            break
+
+    if len(selected) < 150:
+        raise SystemExit(f"only {len(selected)} insertable candidates; need 150")
+
+    for i in range(0, 150, 50):
+        insert_batch(conn, selected[i : i + 50])
+        conn.commit()
+        current = conn.execute(
+            "SELECT COUNT(*) FROM achievers WHERE correction_phase=? AND source_team=?",
+            (PHASE, TEAM),
+        ).fetchone()[0]
+        print(f"committed batch {(i // 50) + 1}: phase_team_count={current}")
+
+    end = conn.execute(
+        "SELECT COUNT(*) FROM achievers WHERE correction_phase=? AND source_team=?",
+        (PHASE, TEAM),
+    ).fetchone()[0]
+    caps = conn.execute(
+        """
+        SELECT COUNT(*)
+        FROM achiever_capabilities
+        WHERE achiever_id IN (
+            SELECT id FROM achievers WHERE correction_phase=? AND source_team=?
+        )
+        """,
+        (PHASE, TEAM),
+    ).fetchone()[0]
+    print(f"inserted_this_run={end - start}")
+    print(f"final_phase_team_count={end}")
+    print(f"capabilities_for_phase_team={caps}")
+
+
+if __name__ == "__main__":
+    main()

