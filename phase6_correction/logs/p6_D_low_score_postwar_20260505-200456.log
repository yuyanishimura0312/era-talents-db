+def parse_rows():
+    rows = []
+    for line in RAW.splitlines():
+        parts = line.split("|")
+        if len(parts) != 11:
+            raise ValueError(f"Bad row with {len(parts)} fields: {line}")
+        name_ja, name_en, birth, death, era, domain, sub, summary, url, low_cap, low_score = parts
+        rows.append(
+            {
+                "name_ja": name_ja,
+                "name_en": name_en,
+                "birth_year": int(birth) if birth else None,
+                "death_year": int(death) if death else None,
+                "era": era,
+                "domain": domain,
+                "sub": sub,
+                "summary": summary,
+                "url": url,
+                "low_cap": low_cap,
+                "low_score": int(low_score),
+            }
+        )
+    return rows
+
+
+def capability_profile(row):
+    low = (
+        row["low_cap"],
+        row["low_score"],
+        f"{row['name_ja']}：{row['summary']}",
+        f"{row['url']} ; Phase 6.D critical low-score record",
+        "低スコア能力。公開記録に基づく批判的評価。",
+    )
+    domain_caps = {
+        "business": [("age_entrepreneur", 7), ("cog_systems", 6)],
+        "politics": [("age_social_change", 7), ("soc_interpersonal", 6)],
+        "sports": [("age_resilience", 8), ("soc_interpersonal", 6)],
+        "media": [("cog_info", 7), ("soc_interpersonal", 6)],
+        "culture_arts": [("cog_creativity", 8), ("age_resilience", 6)],
+        "science": [("cog_logical", 7), ("cog_math", 6)],
+    }.get(row["domain"], [("age_resilience", 6), ("soc_interpersonal", 6)])
+    caps = [low]
+    for cap, score in domain_caps:
+        if cap == row["low_cap"]:
+            cap = "age_meta_learning"
+        caps.append(
+            (
+                cap,
+                score,
+                f"{row['name_ja']}：戦後期に一定の影響力・成果を残したが、同時に批判的評価も残る。",
+                row["url"],
+                "主要能力。低スコア能力と分離して記録。",
+            )
+        )
+    return caps
+
+
+def main():
+    rows = parse_rows()
+    conn = sqlite3.connect(DB)
+    cur = conn.cursor()
+    cur.execute(
+        "SELECT COUNT(*) FROM achievers WHERE correction_phase=? AND source_team=?",
+        (PHASE, TEAM),
+    )
+    already_inserted = cur.fetchone()[0]
+    target_remaining = max(0, 200 - already_inserted)
+    if target_remaining == 0:
+        print("inserted=0")
+        print("already_at_target=1")
+        return
+
+    inserted = 0
+    skipped = []
+
+    for start in range(0, len(rows), 50):
+        batch = rows[start : start + 50]
+        cur.execute("BEGIN")
+        for row in batch:
+            # Required duplicate check, deliberately using IS for NULL-safe equality.
+            cur.execute(
+                "SELECT 1 FROM achievers WHERE name_ja=? AND birth_year IS ? LIMIT 1",
+                (row["name_ja"], row["birth_year"]),
+            )
+            if cur.fetchone():
+                skipped.append(row["name_ja"])
+                continue
+            # Extra guard: avoid adding another same-name record if older imports used a different birth_year.
+            cur.execute("SELECT 1 FROM achievers WHERE name_ja=? LIMIT 1", (row["name_ja"],))
+            if cur.fetchone():
+                skipped.append(row["name_ja"])
+                continue
+            cur.execute(
+                """
+                INSERT INTO achievers (
+                    name_ja, name_en, birth_year, death_year, primary_era_id, domain, sub_domain,
+                    achievement_summary, notable_works, fame_source, fame_score,
+                    is_traditional_great, is_local_excellent, data_completeness,
+                    source_team, source_url, notes, correction_phase
+                ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, '[]', 'wikipedia_or_public_record', 4.0,
+                    0, 0, 80, ?, ?, 'Phase 6.D low_score_postwar: critical biography/scandal/failure balancing record', ?)
+                """,
+                (
+                    row["name_ja"],
+                    row["name_en"],
+                    row["birth_year"],
+                    row["death_year"],
+                    row["era"],
+                    row["domain"],
+                    row["sub"],
+                    row["summary"],
+                    TEAM,
+                    row["url"],
+                    PHASE,
+                ),
+            )
+            achiever_id = cur.lastrowid
+            for cap_id, score, quote, source, notes in capability_profile(row):
+                cur.execute(
+                    """
+                    INSERT INTO achiever_capabilities (
+                        achiever_id, capability_id, score, evidence_quote, evidence_source, notes, is_uniform_bulk
+                    ) VALUES (?, ?, ?, ?, ?, ?, 0)
+                    """,
+                    (achiever_id, cap_id, score, quote, source, notes),
+                )
+            inserted += 1
+            if inserted >= target_remaining:
+                break
+        conn.commit()
+        print(f"batch {start // 50 + 1}: committed {len(batch)} candidates")
+        if inserted >= target_remaining:
+            break
+
+    print(f"inserted={inserted}")
+    print(f"skipped={len(skipped)}")
+    if skipped:
+        print("skipped_names=" + ",".join(skipped))
+
+
+if __name__ == "__main__":
+    main()

