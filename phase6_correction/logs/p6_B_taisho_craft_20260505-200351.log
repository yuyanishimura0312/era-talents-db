+def main():
+    conn = sqlite3.connect(DB_PATH)
+    cur = conn.cursor()
+    inserted = 0
+    skipped = 0
+    batch_no = 1
+    batch_count = 0
+
+    cur.execute("BEGIN")
+    for name, birth, death in CANDIDATES:
