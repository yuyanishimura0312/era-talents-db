-- INSERT前の重複確認: 指定条件 name_ja=? AND birth_year IS ? に相当するNULL生年チェック
SELECT 'duplicate_check_null_birth', COUNT(*) FROM phase6b_candidates c WHERE EXISTS (SELECT 1 FROM achievers a WHERE a.name_ja=c.name_ja AND a.birth_year IS NULL);
SELECT 'duplicate_check_any_birth', COUNT(*) FROM phase6b_candidates c WHERE EXISTS (SELECT 1 FROM achievers a WHERE a.name_ja=c.name_ja);

CREATE TEMP TABLE phase6b_selected AS
SELECT ROW_NUMBER() OVER (ORDER BY rowid) AS rn, *
FROM phase6b_candidates c
WHERE NOT EXISTS (SELECT 1 FROM achievers a WHERE a.name_ja=c.name_ja AND a.birth_year IS NULL)
  AND NOT EXISTS (SELECT 1 FROM achievers a WHERE a.name_ja=c.name_ja)
LIMIT 130;

-- Batch 1: 50件
INSERT INTO achievers (
  name_ja, birth_year, primary_era_id, secondary_era_id, domain, sub_domain,
  achievement_summary, notable_works, family_class, education_path, fame_source,
  fame_score, is_traditional_great, is_local_excellent, data_completeness,
  source_team, source_url, notes, correction_phase
)
SELECT name_ja, NULL, 'showa_pre', 'showa_post', 'craft', sub_domain,
       name_ja || 'は、' || sub_domain || 'の地域工芸・伝統工芸士系統に属する職人・工芸家。昭和前期以前から続く産地技法の継承者として、政治・中央文化偏重を補正するため追加。',
       '[]', 'other', '地域工房・産地内修業', 'traditional_craft_registry',
       2.4, 0, 1, 6,
       'codex_correction_showa_pre_craft', source_url, notes, '6.B'
FROM phase6b_selected WHERE rn BETWEEN 1 AND 50;

