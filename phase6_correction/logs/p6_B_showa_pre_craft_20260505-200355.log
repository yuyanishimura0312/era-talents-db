INSERT INTO achiever_capabilities (achiever_id, capability_id, score, evidence_quote, evidence_source, notes, is_uniform_bulk)
SELECT a.id, 'val_traditional', 9,
       a.sub_domain || 'の伝統技術を担う職人・工芸家として名簿・会員リストに掲載。',
       a.source_url, 'Phase 6.B showa_pre_craft batch evidence', 0
FROM achievers a
WHERE a.correction_phase='6.B' AND a.source_team='codex_correction_showa_pre_craft'
  AND NOT EXISTS (SELECT 1 FROM achiever_capabilities ac WHERE ac.achiever_id=a.id AND ac.capability_id='val_traditional');

INSERT INTO achiever_capabilities (achiever_id, capability_id, score, evidence_quote, evidence_source, notes, is_uniform_bulk)
SELECT a.id, 'cog_creativity', 7,
       a.sub_domain || 'における素材・意匠・技法の実作を通じた創造性を評価。',
       a.source_url, 'Phase 6.B showa_pre_craft batch evidence', 0
FROM achievers a
WHERE a.correction_phase='6.B' AND a.source_team='codex_correction_showa_pre_craft'
  AND NOT EXISTS (SELECT 1 FROM achiever_capabilities ac WHERE ac.achiever_id=a.id AND ac.capability_id='cog_creativity');

INSERT INTO achiever_capabilities (achiever_id, capability_id, score, evidence_quote, evidence_source, notes, is_uniform_bulk)
SELECT a.id, 'age_meta_learning', 6,
       '産地内修業、実務経験、認定・会員掲載により継続的な技能学習と適応を確認。',
       a.source_url, 'Phase 6.B showa_pre_craft batch evidence', 0
FROM achievers a
WHERE a.correction_phase='6.B' AND a.source_team='codex_correction_showa_pre_craft'
  AND NOT EXISTS (SELECT 1 FROM achiever_capabilities ac WHERE ac.achiever_id=a.id AND ac.capability_id='age_meta_learning');

