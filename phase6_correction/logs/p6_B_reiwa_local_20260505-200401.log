+        )
+        inserted += 1
+        batch.append(name)
+        if len(batch) == 50:
+            conn.commit()
+            print(f"committed batch: {inserted} total; last={name}")
+            batch.clear()
+        if inserted == 200:
+            break
+
+    if batch:
+        conn.commit()
+        print(f"committed final batch: {inserted} total; last={batch[-1]}")
+    conn.close()
+    print(f"inserted={inserted}")
+    if inserted != 200:
