    data_completeness INTEGER DEFAULT 0,
    source_team     TEXT,                    -- codex_meiji, codex_taisho, claude_synthesis
    source_url      TEXT,
    notes           TEXT,
    created_at      TEXT DEFAULT (datetime('now'))
, correction_phase TEXT);
