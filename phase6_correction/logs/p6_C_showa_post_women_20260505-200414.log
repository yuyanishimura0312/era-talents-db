+        ("cog_critical", 8, "既存知を検証し研究上の論点を前進させた"),
+        ("age_resilience", 7, "研究職での制度的障壁を越えて活動した"),
+        ("soc_interpersonal", 5, "共同研究・教育上の関係形成はあるが主能力ではないため中位に評価"),
+    ],
+    "arts": [
+        ("cog_creativity", 9, "女性表現者として独自の作品・様式・演技を確立した"),
+        ("val_tolerance", 7, "多様な経験や感情を表現に取り込んだ"),
