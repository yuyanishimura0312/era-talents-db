+def main():
+    conn = sqlite3.connect(DB)
+    cur = conn.cursor()
+    inserted = 0
+    skipped = []
+    seen = set()
+    for p in PEOPLE:
+        key = (p["name_ja"], p["birth_year"])
+        if key in seen:
+            continue
+        seen.add(key)
+        cur.execute("SELECT 1 FROM achievers WHERE name_ja=? AND birth_year IS ?", key)
+        if cur.fetchone():
+            skipped.append(key)
+            continue
