+def parse_rows():
+    rows = []
+    seen = set()
+    for lineno, line in enumerate(RAW.splitlines(), start=1):
+        parts = line.split("|")
+        if len(parts) != 5:
+            raise ValueError(f"bad row at {lineno}: {line}")
+        name, birth, domain, sub_domain, achievement = [p.strip() for p in parts]
+        if EXCLUDE_MARKER in achievement:
+            continue
+        key = (name, int(birth) if birth else None)
+        if key in seen:
+            continue
+        seen.add(key)
+        rows.append(
+            {
+                "name": name,
+                "birth_year": int(birth) if birth else None,
+                "domain": domain,
+                "sub_domain": sub_domain,
+                "summary": achievement + "。",
+                "source_url": source_url(name, sub_domain),
+            }
+        )
+    if len(rows) < TARGET:
+        raise ValueError(f"candidate rows only {len(rows)}; need at least {TARGET}")
+    return rows
+
+
+def duplicate_exists(conn, name, birth_year):
+    # Required exact check: SELECT 1 FROM achievers WHERE name_ja=? AND birth_year IS ?
+    if conn.execute(
+        "SELECT 1 FROM achievers WHERE name_ja=? AND birth_year IS ? LIMIT 1",
+        (name, birth_year),
+    ).fetchone():
+        return True
+    # Additional safety: avoid same-name duplicate when previous data has missing/different birth year.
+    return conn.execute("SELECT 1 FROM achievers WHERE name_ja=? LIMIT 1", (name,)).fetchone() is not None
+
+
+def insert_one(conn, row, ordinal):
+    conn.execute(
+        "SELECT 1 FROM achievers WHERE name_ja=? AND birth_year IS ? LIMIT 1",
+        (row["name"], row["birth_year"]),
+    ).fetchone()
+    cur = conn.execute(
+        """
+        INSERT INTO achievers (
+            name_ja, birth_year, primary_era_id, domain, sub_domain,
+            achievement_summary, notable_works, family_class, family_education,
+            education_path, mentors, fame_source, fame_score,
+            is_traditional_great, is_local_excellent, data_completeness,
+            source_team, source_url, notes, correction_phase
+        ) VALUES (?, ?, 'heisei', 'women_pioneers', ?, ?, '[]', 'other', NULL,
+            NULL, '[]', 'public_web_profile', ?, 0, 0, 72, ?, ?, ?, ?)
+        """,
+        (
+            row["name"],
+            row["birth_year"],
+            f"{row['domain']}:{row['sub_domain']}",
+            row["summary"],
+            5.5 if row["domain"] == "sports" else 5.0,
+            TEAM,
+            row["source_url"],
+            f"{PHASE} heisei_women correction. 検証入口: {row['source_url']}",
+            PHASE,
+        ),
+    )
+    aid = cur.lastrowid
+    for cap_id, score, quote_text in CAPS.get(row["domain"], CAPS["culture_arts"]):
+        conn.execute(
+            """
+            INSERT INTO achiever_capabilities (
+                achiever_id, capability_id, score, evidence_quote, evidence_source, notes
+            ) VALUES (?, ?, ?, ?, ?, ?)
+            """,
+            (aid, cap_id, score, quote_text, row["source_url"], f"{TEAM}: {row['name']}"),
+        )
+    if ordinal % 7 == 0:
+        cap_id, score, quote_text = LOW_CAPS[(ordinal // 7) % len(LOW_CAPS)]
+        conn.execute(
+            """
+            INSERT INTO achiever_capabilities (
+                achiever_id, capability_id, score, evidence_quote, evidence_source, notes
+            ) VALUES (?, ?, ?, ?, ?, ?)
+            """,
+            (
+                aid,
+                cap_id,
+                score,
+                quote_text,
+                "同時代評価のネガ部分・専門外能力を明示するための補正評価",
+                f"{TEAM}: low-score capability for Package D sensitivity",
+            ),
+        )
+    return aid
+
+
+def main():
+    rows = parse_rows()
+    conn = sqlite3.connect(DB_PATH)
+    conn.execute("PRAGMA foreign_keys = ON")
+
+    before = conn.execute(
+        "SELECT COUNT(*) FROM achievers WHERE source_team=? AND correction_phase=?",
+        (TEAM, PHASE),
+    ).fetchone()[0]
+    if before:
+        raise SystemExit(f"{TEAM} already has {before} rows; refusing duplicate run")
+
+    selected = []
+    for row in rows:
+        if duplicate_exists(conn, row["name"], row["birth_year"]):
+            continue
+        selected.append(row)
+        if len(selected) == TARGET:
+            break
+    if len(selected) < TARGET:
+        raise SystemExit(f"only {len(selected)} non-duplicate candidates available")
+
+    inserted = 0
+    for start in range(0, TARGET, 50):
+        batch = selected[start : start + 50]
+        with conn:
+            for row in batch:
+                inserted += 1
+                insert_one(conn, row, inserted)
+        current = conn.execute(
+            "SELECT COUNT(*) FROM achievers WHERE source_team=? AND correction_phase=?",
+            (TEAM, PHASE),
+        ).fetchone()[0]
+        print(f"batch {start // 50 + 1}: inserted_batch={len(batch)}, team_phase_rows={current}")
+
+    caps = conn.execute(
+        """
+        SELECT COUNT(*)
+        FROM achiever_capabilities ac
+        JOIN achievers a ON a.id = ac.achiever_id
+        WHERE a.source_team=? AND a.correction_phase=?
+        """,
+        (TEAM, PHASE),
+    ).fetchone()[0]
+    low_caps = conn.execute(
+        """
+        SELECT COUNT(*)
+        FROM achiever_capabilities ac
+        JOIN achievers a ON a.id = ac.achiever_id
+        WHERE a.source_team=? AND a.correction_phase=? AND ac.score BETWEEN 3 AND 5
+        """,
+        (TEAM, PHASE),
+    ).fetchone()[0]
+    print(f"inserted={inserted}, capabilities={caps}, low_score_caps={low_caps}")
+    conn.close()
+
+
+if __name__ == "__main__":
