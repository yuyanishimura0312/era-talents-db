+            conn.execute(
+                """
+                UPDATE achiever_capabilities
+                SET evidence_source=?, notes=?
+                WHERE achiever_id=?
+                """,
+                (source_url, f"{TEAM}: {name}", aid),
+            )
+    print(f"updated={len(REPLACEMENTS)}")
+
+
+if __name__ == "__main__":
+    main()
