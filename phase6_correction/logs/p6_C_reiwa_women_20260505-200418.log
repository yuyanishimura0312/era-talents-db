    source_url      TEXT,
    notes           TEXT,
    created_at      TEXT DEFAULT (datetime('now'))
, correction_phase TEXT);
CREATE INDEX idx_achievers_era ON achievers(primary_era_id);
CREATE INDEX idx_achievers_domain ON achievers(domain);
CREATE INDEX idx_achievers_birth ON achievers(birth_year);

