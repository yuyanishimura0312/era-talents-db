+def insert_supporting_tables(cur):
+    retrospectives = [
+        ("meiji", "gender", "近代日本のジェンダー秩序と教育機会", "上野千鶴子", 1990, "女性の教育機会は拡大したが、良妻賢母規範が職業的達成の評価を狭めた。"),
