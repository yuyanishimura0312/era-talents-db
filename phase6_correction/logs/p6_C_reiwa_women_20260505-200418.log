+def main():
+    before = None
+    inserted = 0
+    batch_inserted = 0
+    with sqlite3.connect(DB) as conn:
+        cur = conn.cursor()
+        before = cur.execute(
+            "SELECT COUNT(*) FROM achievers WHERE correction_phase=? AND source_team=?",
+            (PHASE, TEAM),
